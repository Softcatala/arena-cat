# Còpia aquest fitxer a .env i ajusta els valors. El .env real no es versiona.

# --- Superusuari de PostgreSQL ---
# Administra l'esquema, executa les migracions d'Alembic i els tests.
POSTGRES_USER=arena_admin
POSTGRES_PASSWORD=canvia_aquesta_contrasenya
POSTGRES_DB=arena_cat
POSTGRES_PORT=5432

# --- Rol d'aplicació amb permisos limitats ---
# Només té DML sobre les taules, no pot alterar l'esquema.
APP_DB_USER=arena_app
APP_DB_PASSWORD=canvia_aquesta_contrasenya_app

# --- URLs de connexió (SQLAlchemy + psycopg 3) ---
# Aplicació: rol limitat sobre la base de dades de l'aplicació.
DATABASE_URL=postgresql+psycopg://arena_app:canvia_aquesta_contrasenya_app@localhost:5432/arena_cat
# Administració: superusuari, per a migracions d'Alembic.
DATABASE_ADMIN_URL=postgresql+psycopg://arena_admin:canvia_aquesta_contrasenya@localhost:5432/arena_cat
# Tests: base de dades aïllada, amb el superusuari (els tests creen i esborren taules).
DATABASE_TEST_URL=postgresql+psycopg://arena_admin:canvia_aquesta_contrasenya@localhost:5432/arena_cat_test
