# Còpia aquest fitxer a .env i ajusta els valors. El .env real no es versiona.

# Host i port de PostgreSQL
DB_HOST=localhost
POSTGRES_PORT=5432

# Superusuari: administra l'esquema, executa les migracions i els tests.
POSTGRES_USER=arena_admin
POSTGRES_PASSWORD=canvia_aquesta_contrasenya
POSTGRES_DB=arena_cat

# Rol d'aplicació amb permisos limitats: el consumeix el servei.
APP_DB_USER=arena_app
APP_DB_PASSWORD=canvia_aquesta_contrasenya_app

# API token per la API de Hugging Face
HF_TOKEN=hf_your_token_here

# Opcional: determina on es guarden els models Hugging Face baixats (i altres dades)
# HF_HOME=.hf-cache
