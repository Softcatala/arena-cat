# Copy this file to .env and adjust the values. The real .env is not versioned.

# PostgreSQL host and port
DB_HOST=127.0.0.1
POSTGRES_PORT=5432

# Superuser: manages the schema, runs the migrations and the tests.
POSTGRES_USER=arena_admin
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=arena_cat

# Application role with limited permissions: used by the service.
APP_DB_USER=arena_app
APP_DB_PASSWORD=change_this_app_password

# Hugging Face API token
HF_TOKEN=hf_your_token_here

# Optional: where downloaded Hugging Face models (and other data) are stored
# HF_HOME=.hf-cache

# HMAC
HMAC_SECRET_KEY=clau_secreta_hmac
EMAIL_HASH_PEPPER=pepper_email_hash
SESSION_SECRET=clau_token_sessio

# Session cookie / authentication
# Duration of the session (and cookie) in hours.
SESSION_TTL_HOURS=24
# Name of the session cookie.
COOKIE_NAME=session_token
# Set to true in production behind HTTPS so the cookie is only sent over TLS.
# Keep false only for local HTTP development.
COOKIE_SECURE=true
# SameSite policy: lax (default), strict, or none.
COOKIE_SAMESITE=lax

# FastAPI
API_PORT=8000
